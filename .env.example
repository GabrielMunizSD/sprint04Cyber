# ── Flask ──────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui

# ── Credenciais do administrador ───────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=suasenhaforte

# ── Comportamento da sessão ────────────────────────────────────────────────────
# Segundos sem presença detectada para encerrar sessão do visitante
IDLE_TIMEOUT=10

# ── Pinos GPIO (Raspberry Pi) ──────────────────────────────────────────────────
PINO_PIR=17   # Sinal OUT do sensor PIR
PINO_LED=22   # LED (anodo no pino, catodo no GND via resistor 330Ω)
